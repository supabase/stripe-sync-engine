{
  "name": "@stripe/stateless-sync",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./source-test": {
      "types": "./src/source-test.ts",
      "import": "./src/source-test.ts",
      "default": "./src/source-test.ts"
    },
    "./destination-test": {
      "types": "./src/destination-test.ts",
      "import": "./src/destination-test.ts",
      "default": "./src/destination-test.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./source-test": {
        "types": "./dist/source-test.d.ts",
        "import": "./dist/source-test.js"
      },
      "./destination-test": {
        "types": "./dist/destination-test.d.ts",
        "import": "./dist/destination-test.js"
      }
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/source-test.ts src/destination-test.ts --format esm,cjs --dts",
    "test": "vitest run"
  },
  "dependencies": {
    "@stripe/protocol": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@stripe/destination-postgres": "workspace:*",
    "@stripe/source-stripe": "workspace:*",
    "@types/node": "^25.5.0",
    "vitest": "^3.2.1"
  },
  "files": [
    "dist"
  ]
}
