{
  "name": "@stripe/protocol",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./cli": {
      "types": "./src/cli.ts",
      "import": "./src/cli.ts",
      "default": "./src/cli.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./cli": {
        "types": "./dist/cli.d.ts",
        "import": "./dist/cli.js",
        "require": "./dist/cli.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --dts",
    "test": "vitest --passWithNoTests"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.5.0",
    "vitest": "^3.2.1"
  },
  "files": [
    "dist"
  ]
}
