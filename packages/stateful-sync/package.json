{
  "name": "@stripe/stateful-sync",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@stripe/stateless-sync": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@stripe/destination-postgres": "workspace:*",
    "@types/node": "^24",
    "@types/pg": "^8.15.4",
    "pg": "^8.16.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
