{
  "name": "@stripe/destination-google-sheets",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "destination-google-sheets": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm,cjs --dts",
    "test": "vitest"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@stripe/protocol": "workspace:*",
    "googleapis": "^148.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
