{
  "name": "@stripe/destination-postgres",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts && mkdir -p dist/database && cp -r src/database/migrations dist/database/migrations",
    "test": "vitest"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@stripe/sync-protocol": "workspace:*",
    "pg": "^8.16.3",
    "yesql": "^7.0.0"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5",
    "@types/yesql": "^4.1.4",
    "vitest": "^3.2.4"
  }
}
