{
  "name": "@stripe/destination-postgres",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "destination-postgres": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm,cjs --dts",
    "test": "vitest"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@stripe/protocol": "workspace:*",
    "@stripe/util-postgres": "workspace:*",
    "pg": "^8.16.3",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@aws-sdk/client-sts": "^3",
    "@aws-sdk/rds-signer": "^3"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-sts": {
      "optional": true
    },
    "@aws-sdk/rds-signer": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aws-sdk/client-sts": "^3.1013.0",
    "@aws-sdk/rds-signer": "^3.1013.0",
    "@types/pg": "^8.15.5",
    "vitest": "^3.2.4"
  }
}
