{
  "compilerOptions": {
    "rootDir": ".",
    "module": "commonjs",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": true
  },
  "include": ["src/server"],
  "exclude": ["src/server/__tests__", "node_modules", "dist"]
}
