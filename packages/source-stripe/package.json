{
  "name": "@tx-stripe/source-stripe",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "source-stripe": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm,cjs --dts",
    "test": "vitest"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@tx-stripe/protocol": "workspace:*",
    "stripe": "^17.7.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.5.0",
    "@types/ws": "^8.18.0",
    "vitest": "^3.2.4"
  }
}
