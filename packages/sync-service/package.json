{
  "name": "@stripe/sync-service",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts && mkdir -p dist/database && cp -r src/database/migrations dist/database/migrations",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@stripe/sync-protocol": "workspace:*",
    "pg": "^8.16.3",
    "yesql": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@stripe/destination-postgres2": "workspace:*",
    "@types/node": "^24",
    "@types/pg": "^8.15.4",
    "@types/yesql": "^4.1.4",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
