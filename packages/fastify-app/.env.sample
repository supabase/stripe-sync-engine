# Fastify server runtime config.
# Merchant-specific values are supplied in the POST /setup and POST /webhook request body.

PORT=8080
MAX_POSTGRES_CONNECTIONS=10

# Optional Postgres SSL settings.
PG_SSL_CONFIG_ENABLED=false
PG_SSL_REJECT_UNAUTHORIZED=false
PG_SSL_REQUEST_CERT=false

# Optional PEM contents.
PG_SSL_CA=
PG_SSL_CERT=
