{
  "name": "@stripe/ts-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./config": {
      "types": "./src/config.ts",
      "import": "./src/config.ts",
      "default": "./src/config.ts"
    },
    "./ndjson": {
      "types": "./src/ndjson.ts",
      "import": "./src/ndjson.ts",
      "default": "./src/ndjson.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./config": {
        "types": "./dist/config.d.ts",
        "import": "./dist/config.js"
      },
      "./ndjson": {
        "types": "./dist/ndjson.d.ts",
        "import": "./dist/ndjson.js"
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^24",
    "vitest": "^3.2"
  },
  "files": [
    "dist"
  ]
}
