{
  "name": "@stripe/ts-cli",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "bin": {
    "ts-cli": "./dist/index.js"
  },
  "main": "./dist/index.cjs",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --shims",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^24",
    "vitest": "^3.2.1"
  },
  "files": [
    "dist"
  ]
}
