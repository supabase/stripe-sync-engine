{
  "name": "@tx-stripe/ts-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./config": {
      "types": "./src/config.ts",
      "import": "./dist/config.js",
      "require": "./dist/config.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/config.ts --format esm,cjs --dts --shims",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^24",
    "tsup": "^8.5.0",
    "vitest": "^3.2"
  },
  "files": [
    "dist"
  ]
}
