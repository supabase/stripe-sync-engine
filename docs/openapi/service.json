    "/syncs/{id}/check": {
      "get": {
        "operationId": "checkSync",
        "tags": ["Sync Operations"],
        "summary": "Check connector connection for a sync",
        "description": "Validates the source/destination config and tests connectivity.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "sync_abc123"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Connection check result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "source": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "string",
                          "enum": ["succeeded", "failed"]
                        },
                        "message": {
                          "type": "string"
                        }
                      },
                      "required": ["status"]
                    },
                    "destination": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "string",
                          "enum": ["succeeded", "failed"]
                        },
                        "message": {
                          "type": "string"
                        }
                      },
                      "required": ["status"]
                    }
                  },
                  "required": ["source", "destination"]
                }
              }
            }
          },
          "404": {
            "description": "Sync not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/syncs/{id}/read": {
      "post": {
        "operationId": "readSync",
        "tags": ["Sync Operations"],
        "summary": "Read records from the sync source",
        "description": "Streams NDJSON messages (records, state, catalog). Optional NDJSON body provides input.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "sync_abc123"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "NDJSON stream of sync messages",
            "content": {
              "application/x-ndjson": {
                "schema": {
                  "type": "string",
                  "description": "Newline-delimited JSON sync messages, one per line",
