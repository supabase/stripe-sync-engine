        "operationId": "readSync",
        "tags": [
          "Sync Operations"
        ],
        "summary": "Read records from the sync source",
        "description": "Streams NDJSON messages (records, state, catalog). Optional NDJSON body provides input.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "sync_abc123"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "NDJSON stream of sync messages",
            "content": {
              "application/x-ndjson": {
                "schema": {
                  "type": "string",
                  "description": "Newline-delimited JSON sync messages, one per line",
                  "example": "{\"type\":\"record\",\"stream\":\"products\",\"data\":{\"id\":\"prod_123\",\"name\":\"Widget\"}}\n"
                }
              }
            }
          },
          "404": {
            "description": "Sync not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/syncs/{id}/write": {
      "post": {
        "operationId": "writeSync",
        "tags": [
          "Sync Operations"
        ],
        "summary": "Write records to the sync destination",
        "description": "Reads NDJSON messages from the request body and writes them to the destination.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "sync_abc123"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-ndjson": {
              "schema": {
                "type": "string",
                "description": "Newline-delimited JSON sync messages, one per line",
                "example": "{\"type\":\"record\",\"stream\":\"products\",\"data\":{\"id\":\"prod_123\",\"name\":\"Widget\"}}\n"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "NDJSON stream of write result messages",
            "content": {
              "application/x-ndjson": {
                "schema": {
                  "type": "string",
                  "description": "Newline-delimited JSON sync messages, one per line",
                  "example": "{\"type\":\"record\",\"stream\":\"products\",\"data\":{\"id\":\"prod_123\",\"name\":\"Widget\"}}\n"
                }
              }
            }
          },
          "400": {
            "description": "Missing request body",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Sync not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/syncs/{id}/run": {
      "post": {
        "operationId": "runSync",
        "tags": [
          "Sync Operations"
        ],
        "summary": "Run sync pipeline (read → write)",
        "description": "Without a request body, reads from the source connector and writes to the destination (backfill mode). With an NDJSON request body, uses the provided messages as input instead of reading from the source (push mode — e.g. piped webhook events).",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "sync_abc123"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "NDJSON stream of sync messages",
            "content": {
              "application/x-ndjson": {
                "schema": {
                  "type": "string",
                  "description": "Newline-delimited JSON sync messages, one per line",
                  "example": "{\"type\":\"record\",\"stream\":\"products\",\"data\":{\"id\":\"prod_123\",\"name\":\"Widget\"}}\n"
                }
              }
            }
          },
          "404": {
            "description": "Sync not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/webhooks/{credential_id}": {
      "post": {
        "operationId": "pushWebhook",
        "tags": [
          "Webhooks"
        ],
        "summary": "Ingest a Stripe webhook event",
        "description": "Receives a raw Stripe webhook and fans it out to all active syncs sharing the credential.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "cred_abc123"
            },
            "required": true,
            "name": "credential_id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Event accepted",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "enum": [
                    "ok"
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}
