                      "nullable": true
                    }
                  },
                  "streams": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "sync_mode": {
                          "type": "string",
                          "enum": ["incremental", "full_refresh"]
                        }
                      },
                      "required": ["name"]
                    }
                  }
                }
              }
            }
