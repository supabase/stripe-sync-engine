{
  "openapi": "3.0.0",
  "info": {
    "title": "Stripe Sync Service",
    "version": "1.0.0",
    "description": "Stripe Sync Service — manage pipelines and webhook ingress.\n\n## Endpoints\n\n| Method | Path | Summary |\n|--------|------|---------|\n| GET | /health | Health check |\n| GET | /pipelines | List pipelines |\n| POST | /pipelines | Create pipeline |\n| GET | /pipelines/{id} | Retrieve pipeline |\n| PATCH | /pipelines/{id} | Update pipeline |\n| DELETE | /pipelines/{id} | Delete pipeline |\n| POST | /pipelines/{id}/setup | Set up destination schema for a pipeline |\n| POST | /pipelines/{id}/teardown | Tear down destination schema for a pipeline |\n| GET | /pipelines/{id}/check | Check connector connection for a pipeline |\n| POST | /pipelines/{id}/read | Read records from the pipeline source |\n| POST | /pipelines/{id}/write | Write records to the pipeline destination |\n| POST | /pipelines/{id}/sync | Run pipeline (read → write) |\n| POST | /pipelines/{id}/pause | Pause a running pipeline (Temporal mode only) |\n| POST | /pipelines/{id}/resume | Resume a paused pipeline (Temporal mode only) |\n| POST | /webhooks/{pipeline_id} | Ingest a Stripe webhook event |"
  },
  "components": {
    "schemas": {},
    "parameters": {}
  },
  "paths": {
    "/health": {
      "get": {
        "operationId": "health",
        "tags": ["Status"],
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Server is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean",
                      "enum": [true]
                    }
                  },
                  "required": ["ok"]
                }
              }
            }
          }
        }
      }
    },
    "/pipelines": {
      "get": {
        "operationId": "listPipelines",
        "tags": ["Pipelines"],
        "summary": "List pipelines",
        "responses": {
          "200": {
            "description": "List of pipelines",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "source": {
                            "type": "object",
                            "properties": {
                              "name": {
                                "type": "string"
                              }
                            },
                            "required": ["name"],
                            "additionalProperties": {
                              "nullable": true
                            }
                          },
                          "destination": {
                            "type": "object",
                            "properties": {
                              "name": {
                                "type": "string"
                              }
                            },
                            "required": ["name"],
                            "additionalProperties": {
                              "nullable": true
                            }
                          },
                          "streams": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "name": {
                                  "type": "string"
                                },
                                "sync_mode": {
                                  "type": "string",
                                  "enum": ["incremental", "full_refresh"]
                                }
                              },
                              "required": ["name"]
                            }
                          }
                        },
                        "required": ["id", "source", "destination"]
                      }
                    },
                    "has_more": {
                      "type": "boolean"
                    }
                  },
                  "required": ["data", "has_more"]
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createPipeline",
        "tags": ["Pipelines"],
        "summary": "Create pipeline",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "source": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      }
                    },
                    "required": ["name"],
                    "additionalProperties": {
                      "nullable": true
                    }
                  },
                  "destination": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      }
                    },
                    "required": ["name"],
                    "additionalProperties": {
                      "nullable": true
                    }
                  },
                  "streams": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "sync_mode": {
                          "type": "string",
                          "enum": ["incremental", "full_refresh"]
                        }
                      },
                      "required": ["name"]
                    }
                  }
                },
                "required": ["source", "destination"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created pipeline",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "source": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        }
                      },
                      "required": ["name"],
                      "additionalProperties": {
                        "nullable": true
                      }
                    },
                    "destination": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        }
                      },
                      "required": ["name"],
                      "additionalProperties": {
                        "nullable": true
                      }
                    },
                    "streams": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string"
                          },
                          "sync_mode": {
                            "type": "string",
                            "enum": ["incremental", "full_refresh"]
                          }
                        },
                        "required": ["name"]
                      }
                    }
                  },
                  "required": ["id", "source", "destination"]
                }
              }
            }
          },
          "400": {
            "description": "Invalid input",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
