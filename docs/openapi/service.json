    "/syncs/{id}/setup": {
      "post": {
        "operationId": "setupSync",
        "tags": ["Sync Operations"],
        "summary": "Set up destination schema for a sync",
        "description": "Creates destination tables and applies migrations. Safe to call multiple times.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "sync_abc123"
            },
            "required": true,
            "name": "id",
            "in": "path"
