    "/pipelines/{id}/setup": {
      "post": {
        "operationId": "setupPipeline",
        "tags": ["Pipeline Operations"],
        "summary": "Set up destination schema for a pipeline",
        "description": "Creates destination tables and applies migrations. Safe to call multiple times.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "pipe_abc123"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "Setup complete"
          },
          "404": {
            "description": "Pipeline not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/pipelines/{id}/teardown": {
      "post": {
        "operationId": "teardownPipeline",
        "tags": ["Pipeline Operations"],
        "summary": "Tear down destination schema for a pipeline",
        "description": "Drops destination tables. Irreversible.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "pipe_abc123"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "Teardown complete"
          },
          "404": {
            "description": "Pipeline not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/pipelines/{id}/check": {
      "get": {
        "operationId": "checkPipeline",
        "tags": ["Pipeline Operations"],
        "summary": "Check connector connection for a pipeline",
        "description": "Validates the source/destination config and tests connectivity.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "pipe_abc123"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Connection check result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "source": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "string",
                          "enum": ["succeeded", "failed"]
                        },
                        "message": {
                          "type": "string"
                        }
                      },
                      "required": ["status"]
                    },
                    "destination": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "string",
                          "enum": ["succeeded", "failed"]
                        },
                        "message": {
                          "type": "string"
                        }
                      },
                      "required": ["status"]
                    }
                  },
                  "required": ["source", "destination"]
                }
              }
            }
          },
          "404": {
            "description": "Pipeline not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/pipelines/{id}/read": {
      "post": {
        "operationId": "readPipeline",
        "tags": ["Pipeline Operations"],
        "summary": "Read records from the pipeline source",
        "description": "Streams NDJSON messages (records, state, catalog). Optional NDJSON body provides input.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "pipe_abc123"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "NDJSON stream of sync messages",
            "content": {
              "application/x-ndjson": {
                "schema": {
                  "type": "string",
                  "description": "Newline-delimited JSON sync messages, one per line",
                  "example": "{\"type\":\"record\",\"stream\":\"products\",\"data\":{\"id\":\"prod_123\",\"name\":\"Widget\"}}\n"
                }
              }
            }
          },
          "404": {
            "description": "Pipeline not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/pipelines/{id}/write": {
      "post": {
        "operationId": "writePipeline",
        "tags": ["Pipeline Operations"],
        "summary": "Write records to the pipeline destination",
        "description": "Reads NDJSON messages from the request body and writes them to the destination.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "pipe_abc123"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-ndjson": {
              "schema": {
                "type": "string",
                "description": "Newline-delimited JSON sync messages, one per line",
                "example": "{\"type\":\"record\",\"stream\":\"products\",\"data\":{\"id\":\"prod_123\",\"name\":\"Widget\"}}\n"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "NDJSON stream of write result messages",
            "content": {
              "application/x-ndjson": {
                "schema": {
                  "type": "string",
                  "description": "Newline-delimited JSON sync messages, one per line",
                  "example": "{\"type\":\"record\",\"stream\":\"products\",\"data\":{\"id\":\"prod_123\",\"name\":\"Widget\"}}\n"
                }
              }
            }
          },
          "400": {
            "description": "Missing request body",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Pipeline not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/pipelines/{id}/sync": {
      "post": {
        "operationId": "syncPipeline",
        "tags": ["Pipeline Operations"],
        "summary": "Run pipeline (read → write)",
        "description": "Without a request body, reads from the source connector and writes to the destination (backfill mode). With an NDJSON request body, uses the provided messages as input instead of reading from the source (push mode — e.g. piped webhook events).",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "pipe_abc123"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "NDJSON stream of sync messages",
            "content": {
              "application/x-ndjson": {
                "schema": {
                  "type": "string",
                  "description": "Newline-delimited JSON sync messages, one per line",
                  "example": "{\"type\":\"record\",\"stream\":\"products\",\"data\":{\"id\":\"prod_123\",\"name\":\"Widget\"}}\n"
                }
              }
            }
          },
          "404": {
            "description": "Pipeline not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/pipelines/{id}/pause": {
      "post": {
        "operationId": "pausePipeline",
        "tags": ["Pipeline Operations"],
        "summary": "Pause a running pipeline (Temporal mode only)",
        "description": "Signals the Temporal workflow to pause. The pipeline will stop processing after the current batch completes. Requires --temporal-address.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "pipe_abc123"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "Pause signal sent"
          },
          "404": {
            "description": "Pipeline not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "Pause requires Temporal mode",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/pipelines/{id}/resume": {
      "post": {
        "operationId": "resumePipeline",
        "tags": ["Pipeline Operations"],
        "summary": "Resume a paused pipeline (Temporal mode only)",
        "description": "Signals the Temporal workflow to resume. Requires --temporal-address.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "pipe_abc123"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "Resume signal sent"
          },
          "404": {
            "description": "Pipeline not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "Resume requires Temporal mode",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/webhooks/{pipeline_id}": {
      "post": {
        "operationId": "pushWebhook",
        "tags": ["Webhooks"],
        "summary": "Ingest a Stripe webhook event",
        "description": "Receives a raw Stripe webhook event, verifies its signature using the pipeline's webhook secret, and enqueues it for processing by the active pipeline.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "pipe_abc123"
            },
            "required": true,
            "name": "pipeline_id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Event accepted",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "enum": ["ok"]
                }
              }
            }
          }
        }
      }
    }
  }
}
