{
  "openapi": "3.1.0",
  "info": {
    "title": "Stripe Sync Engine",
    "version": "1.0.0",
    "description": "Stripe Sync Engine — stateless, one-shot source/destination sync over HTTP.\nAll sync endpoints accept configuration via the `X-Pipeline` header (JSON-encoded PipelineParams). Optional cursor state can be provided via `X-State`.\n\n## Endpoints\n\n| Method | Path | Summary |\n|--------|------|---------|\n| GET | /health | Health check |\n| POST | /setup | Set up destination schema |\n| POST | /teardown | Tear down destination schema |\n| GET | /check | Check connector connection |\n| POST | /read | Read records from source |\n| POST | /write | Write records to destination |\n| POST | /sync | Run sync pipeline (read → write) |\n| GET | /connectors | List available connectors and their config schemas |"
  },
  "components": {
    "schemas": {
      "Message": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/RecordMessage"
          },
          {
            "$ref": "#/components/schemas/StateMessage"
          },
          {
            "$ref": "#/components/schemas/CatalogMessage"
          },
          {
            "$ref": "#/components/schemas/LogMessage"
          },
          {
            "$ref": "#/components/schemas/ErrorMessage"
          },
          {
            "$ref": "#/components/schemas/StreamStatusMessage"
          }
        ],
        "discriminator": {
          "propertyName": "type",
          "mapping": {
            "record": "#/components/schemas/RecordMessage",
            "state": "#/components/schemas/StateMessage",
            "catalog": "#/components/schemas/CatalogMessage",
            "log": "#/components/schemas/LogMessage",
            "error": "#/components/schemas/ErrorMessage",
            "stream_status": "#/components/schemas/StreamStatusMessage"
          }
        }
      },
      "RecordMessage": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["record"]
          },
          "stream": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            }
          },
          "emitted_at": {
            "type": "number"
          }
        },
        "required": ["type", "stream", "data", "emitted_at"]
      },
      "StateMessage": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["state"]
          },
          "stream": {
            "type": "string"
          },
          "data": {
            "nullable": true
          }
        },
        "required": ["type", "stream"]
      },
      "CatalogMessage": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["catalog"]
          },
          "streams": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "primary_key": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              },
              "required": ["name", "primary_key"]
            }
          }
        },
        "required": ["type", "streams"]
      },
      "LogMessage": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["log"]
          },
          "level": {
            "type": "string",
            "enum": ["debug", "info", "warn", "error"]
          },
          "message": {
            "type": "string"
          }
        },
        "required": ["type", "level", "message"]
      },
      "ErrorMessage": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["error"]
          },
          "failure_type": {
            "type": "string",
            "enum": ["config_error", "system_error", "transient_error", "auth_error"]
          },
          "message": {
            "type": "string"
          },
          "stream": {
            "type": "string"
          },
          "stack_trace": {
            "type": "string"
          }
        },
        "required": ["type", "failure_type", "message"]
      },
      "StreamStatusMessage": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["stream_status"]
          },
          "stream": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["started", "running", "complete", "incomplete"]
          }
        },
        "required": ["type", "stream", "status"]
      },
      "DestinationOutput": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/StateMessage"
          },
          {
            "$ref": "#/components/schemas/ErrorMessage"
          },
          {
            "$ref": "#/components/schemas/LogMessage"
          }
        ],
        "discriminator": {
          "propertyName": "type",
          "mapping": {
            "state": "#/components/schemas/StateMessage",
            "error": "#/components/schemas/ErrorMessage",
            "log": "#/components/schemas/LogMessage"
          }
        }
      },
      "PipelineParams": {
        "type": "object",
        "required": ["source", "destination"],
        "properties": {
          "source": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "destination": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "streams": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name"],
              "properties": {
                "name": {
                  "type": "string"
                },
                "sync_mode": {
                  "type": "string",
                  "enum": ["incremental", "full_refresh"]
                },
                "fields": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "parameters": {}
  },
  "paths": {
    "/health": {
      "get": {
        "operationId": "health",
        "tags": ["Status"],
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Server is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean",
                      "enum": [true]
                    }
                  },
                  "required": ["ok"]
                }
              }
            }
          }
        }
      }
    },
    "/setup": {
      "post": {
        "operationId": "setup",
        "tags": ["Stateless Sync API"],
        "summary": "Set up destination schema",
        "description": "Creates destination tables and applies migrations. Safe to call multiple times.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "contentMediaType": "application/json",
              "contentSchema": {
                "$ref": "#/components/schemas/PipelineParams"
              }
            },
            "required": false,
            "description": "JSON-encoded PipelineParams: { source: { name, ...config }, destination: { name, ...config }, streams }",
            "name": "x-pipeline",
            "in": "header"
          }
        ],
        "responses": {
          "204": {
            "description": "Setup complete"
          },
          "400": {
            "description": "Invalid params",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/teardown": {
      "post": {
        "operationId": "teardown",
        "tags": ["Stateless Sync API"],
        "summary": "Tear down destination schema",
        "description": "Drops destination tables. Irreversible.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "contentMediaType": "application/json",
              "contentSchema": {
                "$ref": "#/components/schemas/PipelineParams"
              }
            },
            "required": false,
            "description": "JSON-encoded PipelineParams: { source: { name, ...config }, destination: { name, ...config }, streams }",
            "name": "x-pipeline",
            "in": "header"
          }
        ],
        "responses": {
          "204": {
            "description": "Teardown complete"
          },
          "400": {
            "description": "Invalid params",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/check": {
      "get": {
        "operationId": "check",
        "tags": ["Stateless Sync API"],
        "summary": "Check connector connection",
        "description": "Validates the source/destination config and tests connectivity.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "contentMediaType": "application/json",
              "contentSchema": {
                "$ref": "#/components/schemas/PipelineParams"
              }
            },
            "required": false,
            "description": "JSON-encoded PipelineParams: { source: { name, ...config }, destination: { name, ...config }, streams }",
            "name": "x-pipeline",
            "in": "header"
          }
        ],
        "responses": {
          "200": {
            "description": "Connection check result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "source": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "string",
                          "enum": ["succeeded", "failed"]
                        },
                        "message": {
                          "type": "string"
                        }
                      },
                      "required": ["status"]
                    },
                    "destination": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "string",
                          "enum": ["succeeded", "failed"]
                        },
                        "message": {
                          "type": "string"
                        }
                      },
                      "required": ["status"]
                    }
                  },
                  "required": ["source", "destination"]
                }
              }
            }
          },
          "400": {
            "description": "Invalid params",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/read": {
      "post": {
        "operationId": "read",
        "tags": ["Stateless Sync API"],
        "summary": "Read records from source",
        "description": "Streams NDJSON messages (records, state, catalog). Optional NDJSON body provides catalog/state as input.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "contentMediaType": "application/json",
              "contentSchema": {
                "$ref": "#/components/schemas/PipelineParams"
              }
            },
            "required": false,
            "description": "JSON-encoded PipelineParams: { source: { name, ...config }, destination: { name, ...config }, streams }",
            "name": "x-pipeline",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "contentMediaType": "application/json",
              "contentSchema": {
                "type": "object",
                "additionalProperties": true,
                "description": "Per-stream cursor state keyed by stream name"
              }
            },
            "required": false,
            "description": "JSON-encoded per-stream cursor state. Engine uses this if present, falls back to StateStore.",
            "name": "x-state",
            "in": "header"
          },
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "description": "When set, stops streaming after N state checkpoint messages. Enables page-at-a-time sync.",
              "example": "1"
            },
            "required": false,
            "description": "When set, stops streaming after N state checkpoint messages. Enables page-at-a-time sync.",
            "name": "x-state-checkpoint-limit",
            "in": "header"
          }
        ],
        "responses": {
          "200": {
            "description": "NDJSON stream of sync messages",
            "content": {
              "application/x-ndjson": {
                "schema": {
                  "$ref": "#/components/schemas/Message"
                }
              }
            }
          },
          "400": {
            "description": "Invalid params",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/write": {
      "post": {
        "operationId": "write",
        "tags": ["Stateless Sync API"],
        "summary": "Write records to destination",
        "description": "Reads NDJSON messages from the request body and writes them to the destination. Pipe /read output as input.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "contentMediaType": "application/json",
              "contentSchema": {
                "$ref": "#/components/schemas/PipelineParams"
              }
            },
            "required": false,
            "description": "JSON-encoded PipelineParams: { source: { name, ...config }, destination: { name, ...config }, streams }",
            "name": "x-pipeline",
            "in": "header"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-ndjson": {
              "schema": {
                "$ref": "#/components/schemas/Message"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "NDJSON stream of write result messages",
            "content": {
              "application/x-ndjson": {
                "schema": {
                  "$ref": "#/components/schemas/DestinationOutput"
                }
              }
            }
          },
          "400": {
            "description": "Invalid params or missing body",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/sync": {
      "post": {
        "operationId": "sync",
        "tags": ["Stateless Sync API"],
        "summary": "Run sync pipeline (read → write)",
        "description": "Without a request body, reads from the source connector and writes to the destination (backfill mode). With an NDJSON request body, uses the provided messages as input instead of reading from the source (push mode — e.g. piped webhook events).",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "contentMediaType": "application/json",
              "contentSchema": {
                "$ref": "#/components/schemas/PipelineParams"
              }
            },
            "required": false,
            "description": "JSON-encoded PipelineParams: { source: { name, ...config }, destination: { name, ...config }, streams }",
            "name": "x-pipeline",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "contentMediaType": "application/json",
              "contentSchema": {
                "type": "object",
                "additionalProperties": true,
                "description": "Per-stream cursor state keyed by stream name"
              }
            },
            "required": false,
            "description": "JSON-encoded per-stream cursor state. Engine uses this if present, falls back to StateStore.",
            "name": "x-state",
            "in": "header"
          },
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "description": "When set, stops streaming after N state checkpoint messages. Enables page-at-a-time sync.",
              "example": "1"
            },
            "required": false,
            "description": "When set, stops streaming after N state checkpoint messages. Enables page-at-a-time sync.",
            "name": "x-state-checkpoint-limit",
            "in": "header"
          }
        ],
        "responses": {
          "200": {
            "description": "NDJSON stream of sync messages",
            "content": {
              "application/x-ndjson": {
                "schema": {
                  "$ref": "#/components/schemas/DestinationOutput"
                }
              }
            }
          },
          "400": {
            "description": "Invalid params",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/connectors": {
      "get": {
        "operationId": "listConnectors",
        "tags": ["Connectors"],
        "summary": "List available connectors and their config schemas",
        "responses": {
          "200": {
            "description": "Available connectors with their JSON Schema configs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "sources": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "object",
                        "properties": {
                          "config_schema": {
                            "type": "object",
                            "additionalProperties": {
                              "nullable": true
                            }
                          }
                        },
                        "required": ["config_schema"]
                      }
                    },
                    "destinations": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "object",
                        "properties": {
                          "config_schema": {
                            "type": "object",
                            "additionalProperties": {
                              "nullable": true
                            }
                          }
                        },
                        "required": ["config_schema"]
                      }
                    }
                  },
                  "required": ["sources", "destinations"]
                }
              }
            }
          }
        }
      }
    }
  }
}
