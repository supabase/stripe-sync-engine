{
  "openapi": "3.0.0",
  "info": {
    "title": "Stripe Sync Engine",
    "version": "1.0.0",
    "description": "Stripe Sync Engine — stateless, one-shot source/destination sync over HTTP.\nAll sync endpoints accept configuration via the `X-Sync-Params` header (JSON-encoded SyncParams).\n\n## Endpoints\n\n| Method | Path | Summary |\n|--------|------|---------|\n| GET | /health | Health check |\n| POST | /setup | Set up destination schema |\n| POST | /teardown | Tear down destination schema |\n| GET | /check | Check connector connection |\n| POST | /read | Read records from source |\n| POST | /write | Write records to destination |\n| POST | /sync | Run sync pipeline (read → write) |\n| GET | /connectors | List available connectors and their config schemas |"
  },
  "components": {
    "schemas": {
      "SyncParams": {
        "type": "object",
        "required": ["source", "destination"],
        "properties": {
          "source": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "destination": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "streams": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name"],
              "properties": {
                "name": {
                  "type": "string"
                },
                "sync_mode": {
                  "type": "string",
                  "enum": ["incremental", "full_refresh"]
                },
                "fields": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "state": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "parameters": {}
  },
  "paths": {
    "/health": {
      "get": {
        "operationId": "health",
        "tags": ["Status"],
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Server is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean",
                      "enum": [true]
                    }
                  },
                  "required": ["ok"]
                }
              }
            }
          }
        }
      }
    },
    "/setup": {
      "post": {
        "operationId": "setup",
        "tags": ["Stateless Sync API"],
        "summary": "Set up destination schema",
        "description": "Creates destination tables and applies migrations. Safe to call multiple times.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "description": "JSON-encoded SyncParams: { source: { name, ...config }, destination: { name, ...config }, streams }",
              "example": "{\"source\":{\"name\":\"stripe\",\"api_key\":\"sk_test_...\"},\"destination\":{\"name\":\"postgres\",\"connection_string\":\"postgres://localhost/db\"},\"streams\":[{\"name\":\"products\"}]}"
            },
            "required": false,
            "description": "JSON-encoded SyncParams: { source: { name, ...config }, destination: { name, ...config }, streams }",
            "name": "x-sync-params",
            "in": "header"
          }
        ],
        "responses": {
          "204": {
            "description": "Setup complete"
          },
          "400": {
            "description": "Invalid params",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/teardown": {
      "post": {
        "operationId": "teardown",
        "tags": ["Stateless Sync API"],
        "summary": "Tear down destination schema",
        "description": "Drops destination tables. Irreversible.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "description": "JSON-encoded SyncParams: { source: { name, ...config }, destination: { name, ...config }, streams }",
              "example": "{\"source\":{\"name\":\"stripe\",\"api_key\":\"sk_test_...\"},\"destination\":{\"name\":\"postgres\",\"connection_string\":\"postgres://localhost/db\"},\"streams\":[{\"name\":\"products\"}]}"
            },
            "required": false,
            "description": "JSON-encoded SyncParams: { source: { name, ...config }, destination: { name, ...config }, streams }",
            "name": "x-sync-params",
            "in": "header"
          }
        ],
        "responses": {
          "204": {
            "description": "Teardown complete"
          },
          "400": {
            "description": "Invalid params",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/check": {
      "get": {
        "operationId": "check",
        "tags": ["Stateless Sync API"],
        "summary": "Check connector connection",
        "description": "Validates the source/destination config and tests connectivity.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "description": "JSON-encoded SyncParams: { source: { name, ...config }, destination: { name, ...config }, streams }",
              "example": "{\"source\":{\"name\":\"stripe\",\"api_key\":\"sk_test_...\"},\"destination\":{\"name\":\"postgres\",\"connection_string\":\"postgres://localhost/db\"},\"streams\":[{\"name\":\"products\"}]}"
            },
            "required": false,
            "description": "JSON-encoded SyncParams: { source: { name, ...config }, destination: { name, ...config }, streams }",
            "name": "x-sync-params",
            "in": "header"
          }
        ],
        "responses": {
          "200": {
            "description": "Connection check result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "source": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "string",
                          "enum": ["succeeded", "failed"]
                        },
                        "message": {
                          "type": "string"
                        }
                      },
                      "required": ["status"]
                    },
                    "destination": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "string",
                          "enum": ["succeeded", "failed"]
                        },
                        "message": {
                          "type": "string"
                        }
                      },
                      "required": ["status"]
                    }
                  },
                  "required": ["source", "destination"]
                }
              }
            }
          },
          "400": {
            "description": "Invalid params",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/read": {
      "post": {
        "operationId": "read",
        "tags": ["Stateless Sync API"],
        "summary": "Read records from source",
        "description": "Streams NDJSON messages (records, state, catalog). Optional NDJSON body provides catalog/state as input.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "description": "JSON-encoded SyncParams: { source: { name, ...config }, destination: { name, ...config }, streams }",
              "example": "{\"source\":{\"name\":\"stripe\",\"api_key\":\"sk_test_...\"},\"destination\":{\"name\":\"postgres\",\"connection_string\":\"postgres://localhost/db\"},\"streams\":[{\"name\":\"products\"}]}"
            },
            "required": false,
            "description": "JSON-encoded SyncParams: { source: { name, ...config }, destination: { name, ...config }, streams }",
            "name": "x-sync-params",
            "in": "header"
          }
        ],
        "responses": {
          "200": {
            "description": "NDJSON stream of sync messages",
            "content": {
              "application/x-ndjson": {
                "schema": {
                  "type": "string",
                  "description": "Newline-delimited JSON sync messages, one per line",
                  "example": "{\"type\":\"record\",\"stream\":\"products\",\"data\":{\"id\":\"prod_123\",\"name\":\"Widget\"}}\n"
                }
              }
            }
          },
          "400": {
            "description": "Invalid params",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/write": {
      "post": {
        "operationId": "write",
        "tags": ["Stateless Sync API"],
        "summary": "Write records to destination",
        "description": "Reads NDJSON messages from the request body and writes them to the destination. Pipe /read output as input.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "description": "JSON-encoded SyncParams: { source: { name, ...config }, destination: { name, ...config }, streams }",
              "example": "{\"source\":{\"name\":\"stripe\",\"api_key\":\"sk_test_...\"},\"destination\":{\"name\":\"postgres\",\"connection_string\":\"postgres://localhost/db\"},\"streams\":[{\"name\":\"products\"}]}"
            },
            "required": false,
            "description": "JSON-encoded SyncParams: { source: { name, ...config }, destination: { name, ...config }, streams }",
            "name": "x-sync-params",
            "in": "header"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-ndjson": {
              "schema": {
                "type": "string",
                "description": "Newline-delimited JSON sync messages, one per line",
                "example": "{\"type\":\"record\",\"stream\":\"products\",\"data\":{\"id\":\"prod_123\",\"name\":\"Widget\"}}\n"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "NDJSON stream of write result messages",
            "content": {
              "application/x-ndjson": {
                "schema": {
                  "type": "string",
                  "description": "Newline-delimited JSON sync messages, one per line",
                  "example": "{\"type\":\"record\",\"stream\":\"products\",\"data\":{\"id\":\"prod_123\",\"name\":\"Widget\"}}\n"
                }
              }
            }
          },
          "400": {
            "description": "Invalid params or missing body",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/sync": {
      "post": {
        "operationId": "sync",
        "tags": ["Stateless Sync API"],
        "summary": "Run sync pipeline (read → write)",
        "description": "Without a request body, reads from the source connector and writes to the destination (backfill mode). With an NDJSON request body, uses the provided messages as input instead of reading from the source (push mode — e.g. piped webhook events).",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "description": "JSON-encoded SyncParams: { source: { name, ...config }, destination: { name, ...config }, streams }",
              "example": "{\"source\":{\"name\":\"stripe\",\"api_key\":\"sk_test_...\"},\"destination\":{\"name\":\"postgres\",\"connection_string\":\"postgres://localhost/db\"},\"streams\":[{\"name\":\"products\"}]}"
            },
            "required": false,
            "description": "JSON-encoded SyncParams: { source: { name, ...config }, destination: { name, ...config }, streams }",
            "name": "x-sync-params",
            "in": "header"
          }
        ],
        "responses": {
          "200": {
            "description": "NDJSON stream of sync messages",
            "content": {
              "application/x-ndjson": {
                "schema": {
                  "type": "string",
                  "description": "Newline-delimited JSON sync messages, one per line",
                  "example": "{\"type\":\"record\",\"stream\":\"products\",\"data\":{\"id\":\"prod_123\",\"name\":\"Widget\"}}\n"
                }
              }
            }
          },
          "400": {
            "description": "Invalid params",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/connectors": {
      "get": {
        "operationId": "listConnectors",
        "tags": ["Connectors"],
        "summary": "List available connectors and their config schemas",
        "responses": {
          "200": {
            "description": "Available connectors with their JSON Schema configs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "sources": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "object",
                        "properties": {
                          "config_schema": {
                            "type": "object",
                            "additionalProperties": {
                              "nullable": true
                            }
                          }
                        },
                        "required": ["config_schema"]
                      }
                    },
                    "destinations": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "object",
                        "properties": {
                          "config_schema": {
                            "type": "object",
                            "additionalProperties": {
                              "nullable": true
                            }
                          }
                        },
                        "required": ["config_schema"]
                      }
                    }
                  },
                  "required": ["sources", "destinations"]
                }
              }
            }
          }
        }
      }
    }
  }
}
