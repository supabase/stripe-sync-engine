{
  "name": "@stripe/sync-engine-stateful-api",
  "version": "0.1.0",
  "private": false,
  "description": "Stripe Sync Engine stateful HTTP API — persistent sync with credential and state management",
  "type": "module",
  "main": "./dist/index.cjs",
  "bin": {
    "sync-engine-stateful-api": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/app.ts --format esm,cjs --dts --shims",
    "dev": "tsup src/index.ts src/app.ts --format esm --shims --watch",
    "test": "vitest run"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@hono/node-server": "^1",
    "@hono/swagger-ui": "^0.6",
    "@hono/zod-openapi": "^1.2",
    "@stripe/sync-engine-stateless-api": "workspace:*",
    "@stripe/stateful-sync": "workspace:*",
    "hono": "^4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24",
    "esbuild": "^0.27.2",
    "tsup": "^8.5.0",
    "vitest": "^3.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stripe/sync-engine.git"
  },
  "homepage": "https://github.com/stripe/sync-engine#readme",
  "bugs": {
    "url": "https://github.com/stripe/sync-engine/issues"
  },
  "keywords": [
    "stripe",
    "sync",
    "stateful",
    "api",
    "typescript"
  ],
  "author": "Stripe <https://stripe.com/>"
}
