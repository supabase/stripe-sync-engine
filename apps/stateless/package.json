{
  "name": "@stripe/sync-engine-stateless",
  "version": "0.1.0",
  "private": false,
  "description": "Stripe Sync Engine stateless app — CLI and HTTP API for one-shot sync",
  "type": "module",
  "main": "./dist/index.cjs",
  "bin": {
    "sync-engine-stateless": "./dist/cli/index.js",
    "sync-engine-stateless-api": "./dist/api/index.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./app": {
      "types": "./src/api/app.ts",
      "import": "./dist/api/app.js",
      "require": "./dist/api/app.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli/index.ts src/api/index.ts src/api/app.ts --format esm,cjs --dts --shims",
    "dev": "tsup src/index.ts src/cli/index.ts src/api/index.ts src/api/app.ts --format esm --shims --watch",
    "test": "vitest --passWithNoTests"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@hono/node-server": "^1",
    "@stripe/stateless-sync": "workspace:*",
    "@stripe/ts-cli": "workspace:*",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "hono": "^4"
  },
  "devDependencies": {
    "@stripe/destination-postgres": "workspace:*",
    "@stripe/source-stripe": "workspace:*",
    "@types/node": "^24.10.1",
    "@vitest/ui": "^4.0.9",
    "esbuild": "^0.27.2",
    "pg": "^8.16.3",
    "tsup": "^8.5.0",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stripe/sync-engine.git"
  },
  "homepage": "https://github.com/stripe/sync-engine#readme",
  "bugs": {
    "url": "https://github.com/stripe/sync-engine/issues"
  },
  "keywords": [
    "stripe",
    "sync",
    "database",
    "typescript"
  ],
  "author": "Stripe <https://stripe.com/>"
}
