{
  "name": "@stripe/sync-engine-stateless",
  "version": "0.1.0",
  "private": false,
  "description": "Stripe Sync Engine stateless app — CLI and HTTP API for one-shot sync",
  "type": "module",
  "bin": {
    "sync-engine-stateless": "./dist/cli/index.js",
    "sync-engine-stateless-api": "./dist/api/index.js"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./app": {
      "bun": "./src/api/app.ts",
      "types": "./dist/api/app.d.ts",
      "import": "./dist/api/app.js"
    }
  },
  "scripts": {
    "build": "tsc && node ../../scripts/fix-shebangs.mjs dist/cli/index.js dist/api/index.js",
    "dev": "tsc --watch",
    "test": "vitest --passWithNoTests"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@hono/node-server": "^1",
    "@hono/swagger-ui": "^0.6",
    "@hono/zod-openapi": "^1.2",
    "@stripe/sync-lib-stateless": "workspace:*",
    "@stripe/sync-ts-cli": "workspace:*",
    "citty": "^0.1.6",
    "dotenv": "^16.4.7",
    "hono": "^4"
  },
  "devDependencies": {
    "@stripe/sync-destination-postgres": "workspace:*",
    "@stripe/sync-source-stripe": "workspace:*",
    "@types/node": "^24.10.1",
    "@vitest/ui": "^4.0.9",
    "esbuild": "^0.27.2",
    "pg": "^8.16.3",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stripe/sync-engine.git"
  },
  "homepage": "https://github.com/stripe/sync-engine#readme",
  "bugs": {
    "url": "https://github.com/stripe/sync-engine/issues"
  },
  "keywords": [
    "stripe",
    "sync",
    "database",
    "typescript"
  ],
  "author": "Stripe <https://stripe.com/>"
}
