{
  "name": "@stripe/sync-engine-cli",
  "version": "0.1.0",
  "private": false,
  "description": "Stripe Sync Engine CLI — composition root for sync pipeline",
  "type": "module",
  "main": "./dist/index.cjs",
  "bin": {
    "sync-engine": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./cli": {
      "types": "./src/cli/lib.ts",
      "import": "./dist/cli/lib.js",
      "require": "./dist/cli/lib.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli/index.ts src/cli/lib.ts --format esm,cjs --dts --shims",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "sync": "pnpm run build && node dist/cli/index.js sync",
    "dev": "tsup src/index.ts src/cli/index.ts src/cli/lib.ts --format esm --shims --watch"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@stripe/sync-protocol": "workspace:*",
    "@stripe/source-stripe": "workspace:*",
    "@stripe/destination-postgres": "workspace:*",
    "@stripe/destination-google-sheets": "workspace:*",
    "@stripe/orchestrator-postgres": "workspace:*",
    "@stripe/integration-supabase": "workspace:*",
    "@ngrok/ngrok": "^1.4.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "inquirer": "^12.3.0",
    "papaparse": "5.4.1",
    "pg": "^8.16.3",
    "stripe": "^17.7.0",
    "ws": "^8.18.0",
    "yesql": "^7.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^24.10.1",
    "@types/papaparse": "5.3.16",
    "@types/pg": "^8.15.5",
    "@types/ws": "^8.5.13",
    "@types/yesql": "^4.1.4",
    "@vitest/ui": "^4.0.9",
    "esbuild": "^0.27.2",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stripe/sync-engine.git"
  },
  "homepage": "https://github.com/stripe/sync-engine#readme",
  "bugs": {
    "url": "https://github.com/stripe/sync-engine/issues"
  },
  "keywords": [
    "stripe",
    "postgres",
    "sync",
    "webhooks",
    "supabase",
    "billing",
    "database",
    "typescript"
  ],
  "author": "Stripe <https://stripe.com/>"
}
