{
  "openapi": "3.1.0",
  "info": {
    "title": "Stripe Sync Engine",
    "version": "1.0.0",
    "description": "Stripe Sync Engine — stateless, one-shot source/destination sync over HTTP.\nAll sync endpoints accept configuration via the `X-Pipeline` header (JSON-encoded PipelineConfig). Optional cursor state can be provided via `X-State`.\n\n## Endpoints\n\n| Method | Path | Summary |\n|--------|------|---------|\n| GET | /health | Health check |\n| POST | /setup | Set up destination schema |\n| POST | /teardown | Tear down destination schema |\n| GET | /check | Check connector connection |\n| POST | /discover | Discover available streams |\n| POST | /read | Read records from source |\n| POST | /write | Write records to destination |\n| POST | /sync | Run sync pipeline (read → write) |\n| GET | /connectors | List available connectors and their config schemas |"
  },
  "paths": {
    "/health": {
      "get": {
        "operationId": "health",
        "tags": ["Status"],
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Server is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "ok": { "type": "boolean", "const": true } },
                  "required": ["ok"],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/setup": {
      "post": {
        "operationId": "setup",
        "tags": ["Stateless Sync API"],
        "summary": "Set up destination schema",
        "description": "Creates destination tables and applies migrations. Safe to call multiple times.",
        "parameters": [
          {
            "in": "header",
            "name": "x-pipeline",
            "description": "JSON-encoded PipelineConfig: { source: { type, ...config }, destination: { type, ...config }, streams }",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/PipelineConfig" } }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Setup complete",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "propertyNames": { "type": "string" },
                  "additionalProperties": {}
                }
              }
            }
          },
          "400": {
            "description": "Invalid params",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "error": {} },
                  "required": ["error"],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/teardown": {
      "post": {
        "operationId": "teardown",
        "tags": ["Stateless Sync API"],
        "summary": "Tear down destination schema",
        "description": "Drops destination tables. Irreversible.",
        "parameters": [
          {
            "in": "header",
            "name": "x-pipeline",
            "description": "JSON-encoded PipelineConfig: { source: { type, ...config }, destination: { type, ...config }, streams }",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/PipelineConfig" } }
            }
          }
        ],
        "responses": {
          "204": { "description": "Teardown complete" },
          "400": {
            "description": "Invalid params",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "error": {} },
                  "required": ["error"],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/check": {
      "get": {
        "operationId": "check",
        "tags": ["Stateless Sync API"],
        "summary": "Check connector connection",
        "description": "Validates the source/destination config and tests connectivity.",
        "parameters": [
          {
            "in": "header",
            "name": "x-pipeline",
            "description": "JSON-encoded PipelineConfig: { source: { type, ...config }, destination: { type, ...config }, streams }",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/PipelineConfig" } }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Connection check result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "source": {
                      "type": "object",
                      "properties": {
                        "status": { "type": "string", "enum": ["succeeded", "failed"] },
                        "message": { "type": "string" }
                      },
                      "required": ["status"],
                      "additionalProperties": false
                    },
                    "destination": {
                      "type": "object",
                      "properties": {
                        "status": { "type": "string", "enum": ["succeeded", "failed"] },
                        "message": { "type": "string" }
                      },
                      "required": ["status"],
                      "additionalProperties": false
                    }
                  },
                  "required": ["source", "destination"],
                  "additionalProperties": false
                }
              }
            }
          },
          "400": {
            "description": "Invalid params",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "error": {} },
                  "required": ["error"],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/discover": {
      "post": {
        "operationId": "discover",
        "tags": ["Stateless Sync API"],
        "summary": "Discover available streams",
        "description": "Returns the catalog of available streams for the configured source. Each stream includes its name, primary key, and optional JSON schema.",
        "parameters": [
          {
            "in": "header",
            "name": "x-pipeline",
            "description": "JSON-encoded PipelineConfig: { source: { type, ...config }, destination: { type, ...config }, streams }",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/PipelineConfig" } }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Available streams",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CatalogMessageOutput" }
              }
            }
          },
          "400": {
            "description": "Invalid params",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "error": {} },
                  "required": ["error"],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/read": {
      "post": {
        "operationId": "read",
        "tags": ["Stateless Sync API"],
        "summary": "Read records from source",
        "description": "Streams NDJSON messages (records, state, catalog). Optional NDJSON body provides live events as input.",
        "parameters": [
          {
            "in": "header",
            "name": "x-pipeline",
            "description": "JSON-encoded PipelineConfig: { source: { type, ...config }, destination: { type, ...config }, streams }",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/PipelineConfig" } }
            }
          },
          {
            "in": "header",
            "name": "x-state",
            "description": "JSON-encoded per-stream cursor state. Engine uses this if present, falls back to StateStore.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true,
                  "description": "Per-stream cursor state keyed by stream name"
                }
              }
            }
          },
          {
            "in": "query",
            "name": "state_limit",
            "schema": {
              "description": "Stop streaming after N state messages.",
              "example": "100",
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "description": "Stop streaming after N state messages."
          },
          {
            "in": "query",
            "name": "time_limit",
            "schema": {
              "description": "Stop streaming after N seconds.",
              "example": "10",
              "type": "number",
              "exclusiveMinimum": 0
            },
            "description": "Stop streaming after N seconds."
          }
        ],
        "responses": {
          "200": {
            "description": "NDJSON stream of sync messages",
            "content": {
              "application/x-ndjson": { "schema": { "$ref": "#/components/schemas/MessageOutput" } }
            }
          },
          "400": {
            "description": "Invalid params",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "error": {} },
                  "required": ["error"],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/write": {
      "post": {
        "operationId": "write",
        "tags": ["Stateless Sync API"],
        "summary": "Write records to destination",
        "description": "Reads NDJSON messages from the request body and writes them to the destination. Pipe /read output as input.",
        "parameters": [
          {
            "in": "header",
            "name": "x-pipeline",
            "description": "JSON-encoded PipelineConfig: { source: { type, ...config }, destination: { type, ...config }, streams }",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/PipelineConfig" } }
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-ndjson": { "schema": { "$ref": "#/components/schemas/Message" } }
          }
        },
        "responses": {
          "200": {
            "description": "NDJSON stream of write result messages",
            "content": {
              "application/x-ndjson": {
                "schema": { "$ref": "#/components/schemas/DestinationOutput" }
              }
            }
          },
          "400": {
            "description": "Invalid params",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "error": {} },
                  "required": ["error"],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/sync": {
      "post": {
        "operationId": "sync",
        "tags": ["Stateless Sync API"],
        "summary": "Run sync pipeline (read → write)",
        "description": "Without a request body, reads from the source connector and writes to the destination (backfill mode). With an NDJSON request body, uses the provided messages as input instead of reading from the source (push mode — e.g. piped webhook events).",
        "parameters": [
          {
            "in": "header",
            "name": "x-pipeline",
            "description": "JSON-encoded PipelineConfig: { source: { type, ...config }, destination: { type, ...config }, streams }",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/PipelineConfig" } }
            }
          },
          {
            "in": "header",
            "name": "x-state",
            "description": "JSON-encoded per-stream cursor state. Engine uses this if present, falls back to StateStore.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true,
                  "description": "Per-stream cursor state keyed by stream name"
                }
              }
            }
          },
          {
            "in": "query",
            "name": "state_limit",
            "schema": {
              "description": "Stop streaming after N state messages.",
              "example": "100",
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "description": "Stop streaming after N state messages."
          },
          {
            "in": "query",
            "name": "time_limit",
            "schema": {
              "description": "Stop streaming after N seconds.",
              "example": "10",
              "type": "number",
              "exclusiveMinimum": 0
            },
            "description": "Stop streaming after N seconds."
          }
        ],
        "responses": {
          "200": {
            "description": "NDJSON stream of sync messages",
            "content": {
              "application/x-ndjson": {
                "schema": { "$ref": "#/components/schemas/DestinationOutput" }
              }
            }
          },
          "400": {
            "description": "Invalid params",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "error": {} },
                  "required": ["error"],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/connectors": {
      "get": {
        "operationId": "listConnectors",
        "tags": ["Connectors"],
        "summary": "List available connectors and their config schemas",
        "responses": {
          "200": {
            "description": "Available connectors with their JSON Schema configs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "sources": {
                      "type": "object",
                      "propertyNames": { "type": "string" },
                      "additionalProperties": {
                        "type": "object",
                        "properties": {
                          "config_schema": {
                            "type": "object",
                            "propertyNames": { "type": "string" },
                            "additionalProperties": {}
                          }
                        },
                        "required": ["config_schema"],
                        "additionalProperties": false
                      }
                    },
                    "destinations": {
                      "type": "object",
                      "propertyNames": { "type": "string" },
                      "additionalProperties": {
                        "type": "object",
                        "properties": {
                          "config_schema": {
                            "type": "object",
                            "propertyNames": { "type": "string" },
                            "additionalProperties": {}
                          }
                        },
                        "required": ["config_schema"],
                        "additionalProperties": false
                      }
                    }
                  },
                  "required": ["sources", "destinations"],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Message": {
        "oneOf": [
          { "$ref": "#/components/schemas/RecordMessage" },
          { "$ref": "#/components/schemas/StateMessage" },
          { "$ref": "#/components/schemas/CatalogMessage" },
          { "$ref": "#/components/schemas/LogMessage" },
          { "$ref": "#/components/schemas/ErrorMessage" },
          { "$ref": "#/components/schemas/StreamStatusMessage" },
          { "$ref": "#/components/schemas/EofMessage" }
        ],
        "type": "object",
        "discriminator": {
          "propertyName": "type",
          "mapping": {
            "record": "#/components/schemas/RecordMessage",
            "state": "#/components/schemas/StateMessage",
            "catalog": "#/components/schemas/CatalogMessage",
            "log": "#/components/schemas/LogMessage",
            "error": "#/components/schemas/ErrorMessage",
            "stream_status": "#/components/schemas/StreamStatusMessage",
            "eof": "#/components/schemas/EofMessage"
          }
        }
      },
      "RecordMessage": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "const": "record" },
          "stream": {
            "type": "string",
            "description": "Stream (table) name this record belongs to."
          },
          "data": {
            "type": "object",
            "propertyNames": { "type": "string" },
            "additionalProperties": {},
            "description": "The record payload as a key-value map."
          },
          "emitted_at": {
            "type": "string",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
            "description": "ISO 8601 timestamp when the record was emitted by the source."
          }
        },
        "required": ["type", "stream", "data", "emitted_at"],
        "description": "One record for one stream."
      },
      "StateMessage": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "const": "state" },
          "stream": { "type": "string", "description": "Stream being checkpointed." },
          "data": {
            "description": "Opaque checkpoint data — only the source understands its contents. The orchestrator persists it keyed by stream and passes it back on resume."
          }
        },
        "required": ["type", "stream", "data"],
        "description": "Per-stream checkpoint for resumable syncs. Emitted by the source after each page/batch so the orchestrator can persist progress."
      },
      "CatalogMessage": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "const": "catalog" },
          "streams": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Collection name (e.g. \"customers\", \"invoices\", \"pg_public.users\")."
                },
                "primary_key": {
                  "type": "array",
                  "items": { "type": "array", "items": { "type": "string" } },
                  "description": "Paths to fields that uniquely identify a record within this stream. Supports composite keys and nested paths. e.g. [[\"id\"]] or [[\"account_id\"], [\"created\"]]"
                },
                "json_schema": {
                  "description": "JSON Schema describing the record shape. Discovered at runtime or provided by config.",
                  "type": "object",
                  "propertyNames": { "type": "string" },
                  "additionalProperties": {}
                },
                "metadata": {
                  "description": "Source-specific metadata that applies to every record in this stream. The destination can use these for schema naming, partitioning, etc. Examples: Stripe: { api_version, account_id, live_mode }.",
                  "type": "object",
                  "propertyNames": { "type": "string" },
                  "additionalProperties": {}
                }
              },
              "required": ["name", "primary_key"],
              "description": "A named collection of records — analogous to a table or API resource."
            },
            "description": "All streams available from this source."
          }
        },
        "required": ["type", "streams"],
        "description": "Catalog of available streams. Emitted by a source during discover()."
      },
      "LogMessage": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "const": "log" },
          "level": {
            "type": "string",
            "enum": ["debug", "info", "warn", "error"],
            "description": "Log severity level."
          },
          "message": { "type": "string", "description": "Human-readable log message." }
        },
        "required": ["type", "level", "message"],
        "description": "Structured log output from a source or destination."
      },
      "ErrorMessage": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "const": "error" },
          "failure_type": {
            "type": "string",
            "enum": ["config_error", "system_error", "transient_error", "auth_error"],
            "description": "Error category — lets the orchestrator decide whether to retry, alert, or abort."
          },
          "message": { "type": "string", "description": "Human-readable error description." },
          "stream": {
            "description": "Stream that triggered the error, if applicable.",
            "type": "string"
          },
          "stack_trace": { "description": "Full stack trace for debugging.", "type": "string" }
        },
        "required": ["type", "failure_type", "message"],
        "description": "Structured error from a source or destination."
      },
      "StreamStatusMessage": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "const": "stream_status" },
          "stream": { "type": "string", "description": "Stream being reported on." },
          "status": {
            "type": "string",
            "enum": ["started", "running", "complete", "incomplete"],
            "description": "Current phase of the stream within this sync run."
          }
        },
        "required": ["type", "stream", "status"],
        "description": "Per-stream status update from a source. Enables progress reporting in CLI / dashboard."
      },
      "EofMessage": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "const": "eof" },
          "reason": { "type": "string", "enum": ["complete", "state_limit", "time_limit", "error"] }
        },
        "required": ["type", "reason"]
      },
      "DestinationOutput": {
        "oneOf": [
          { "$ref": "#/components/schemas/StateMessageOutput" },
          { "$ref": "#/components/schemas/ErrorMessageOutput" },
          { "$ref": "#/components/schemas/LogMessageOutput" },
          { "$ref": "#/components/schemas/EofMessageOutput" }
        ],
        "type": "object",
        "discriminator": {
          "propertyName": "type",
          "mapping": {
            "state": "#/components/schemas/StateMessageOutput",
            "error": "#/components/schemas/ErrorMessageOutput",
            "log": "#/components/schemas/LogMessageOutput",
            "eof": "#/components/schemas/EofMessageOutput"
          }
        }
      },
      "CatalogMessageOutput": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "const": "catalog" },
          "streams": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Collection name (e.g. \"customers\", \"invoices\", \"pg_public.users\")."
                },
                "primary_key": {
                  "type": "array",
                  "items": { "type": "array", "items": { "type": "string" } },
                  "description": "Paths to fields that uniquely identify a record within this stream. Supports composite keys and nested paths. e.g. [[\"id\"]] or [[\"account_id\"], [\"created\"]]"
                },
                "json_schema": {
                  "description": "JSON Schema describing the record shape. Discovered at runtime or provided by config.",
                  "type": "object",
                  "propertyNames": { "type": "string" },
                  "additionalProperties": {}
                },
                "metadata": {
                  "description": "Source-specific metadata that applies to every record in this stream. The destination can use these for schema naming, partitioning, etc. Examples: Stripe: { api_version, account_id, live_mode }.",
                  "type": "object",
                  "propertyNames": { "type": "string" },
                  "additionalProperties": {}
                }
              },
              "required": ["name", "primary_key"],
              "additionalProperties": false,
              "description": "A named collection of records — analogous to a table or API resource."
            },
            "description": "All streams available from this source."
          }
        },
        "required": ["type", "streams"],
        "additionalProperties": false,
        "description": "Catalog of available streams. Emitted by a source during discover()."
      },
      "MessageOutput": {
        "oneOf": [
          { "$ref": "#/components/schemas/RecordMessageOutput" },
          { "$ref": "#/components/schemas/StateMessageOutput" },
          { "$ref": "#/components/schemas/CatalogMessageOutput" },
          { "$ref": "#/components/schemas/LogMessageOutput" },
          { "$ref": "#/components/schemas/ErrorMessageOutput" },
          { "$ref": "#/components/schemas/StreamStatusMessageOutput" },
          { "$ref": "#/components/schemas/EofMessageOutput" }
        ],
        "type": "object",
        "discriminator": {
          "propertyName": "type",
          "mapping": {
            "record": "#/components/schemas/RecordMessageOutput",
            "state": "#/components/schemas/StateMessageOutput",
            "catalog": "#/components/schemas/CatalogMessageOutput",
            "log": "#/components/schemas/LogMessageOutput",
            "error": "#/components/schemas/ErrorMessageOutput",
            "stream_status": "#/components/schemas/StreamStatusMessageOutput",
            "eof": "#/components/schemas/EofMessageOutput"
          }
        }
      },
      "RecordMessageOutput": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "const": "record" },
          "stream": {
            "type": "string",
            "description": "Stream (table) name this record belongs to."
          },
          "data": {
            "type": "object",
            "propertyNames": { "type": "string" },
            "additionalProperties": {},
            "description": "The record payload as a key-value map."
          },
          "emitted_at": {
            "type": "string",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
            "description": "ISO 8601 timestamp when the record was emitted by the source."
          }
        },
        "required": ["type", "stream", "data", "emitted_at"],
        "additionalProperties": false,
        "description": "One record for one stream."
      },
      "StateMessageOutput": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "const": "state" },
          "stream": { "type": "string", "description": "Stream being checkpointed." },
          "data": {
            "description": "Opaque checkpoint data — only the source understands its contents. The orchestrator persists it keyed by stream and passes it back on resume."
          }
        },
        "required": ["type", "stream", "data"],
        "additionalProperties": false,
        "description": "Per-stream checkpoint for resumable syncs. Emitted by the source after each page/batch so the orchestrator can persist progress."
      },
      "LogMessageOutput": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "const": "log" },
          "level": {
            "type": "string",
            "enum": ["debug", "info", "warn", "error"],
            "description": "Log severity level."
          },
          "message": { "type": "string", "description": "Human-readable log message." }
        },
        "required": ["type", "level", "message"],
        "additionalProperties": false,
        "description": "Structured log output from a source or destination."
      },
      "ErrorMessageOutput": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "const": "error" },
          "failure_type": {
            "type": "string",
            "enum": ["config_error", "system_error", "transient_error", "auth_error"],
            "description": "Error category — lets the orchestrator decide whether to retry, alert, or abort."
          },
          "message": { "type": "string", "description": "Human-readable error description." },
          "stream": {
            "description": "Stream that triggered the error, if applicable.",
            "type": "string"
          },
          "stack_trace": { "description": "Full stack trace for debugging.", "type": "string" }
        },
        "required": ["type", "failure_type", "message"],
        "additionalProperties": false,
        "description": "Structured error from a source or destination."
      },
      "StreamStatusMessageOutput": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "const": "stream_status" },
          "stream": { "type": "string", "description": "Stream being reported on." },
          "status": {
            "type": "string",
            "enum": ["started", "running", "complete", "incomplete"],
            "description": "Current phase of the stream within this sync run."
          }
        },
        "required": ["type", "stream", "status"],
        "additionalProperties": false,
        "description": "Per-stream status update from a source. Enables progress reporting in CLI / dashboard."
      },
      "EofMessageOutput": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "const": "eof" },
          "reason": { "type": "string", "enum": ["complete", "state_limit", "time_limit", "error"] }
        },
        "required": ["type", "reason"],
        "additionalProperties": false
      },
      "StripeSourceConfig": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["stripe"] },
          "api_key": {
            "type": "string",
            "description": "Stripe API key (sk_test_... or sk_live_...)"
          },
          "account_id": {
            "description": "Stripe account ID (resolved from API if omitted)",
            "type": "string"
          },
          "livemode": { "description": "Whether this is a live mode sync", "type": "boolean" },
          "api_version": {
            "description": "Stripe API version (e.g. 2025-04-30.basil)",
            "type": "string"
          },
          "base_url": {
            "description": "Override the Stripe API base URL (e.g. http://localhost:12111 for stripe-mock)",
            "type": "string",
            "format": "uri"
          },
          "webhook_url": {
            "description": "URL for managed webhook endpoint registration",
            "type": "string",
            "format": "uri"
          },
          "webhook_secret": {
            "description": "Webhook signing secret (whsec_...) for signature verification",
            "type": "string"
          },
          "websocket": {
            "description": "Enable WebSocket streaming for live events",
            "type": "boolean"
          },
          "poll_events": {
            "description": "Enable events API polling for incremental sync after backfill",
            "type": "boolean"
          },
          "webhook_port": {
            "description": "Port for built-in webhook HTTP listener (e.g. 4242)",
            "type": "integer",
            "minimum": -9007199254740991,
            "maximum": 9007199254740991
          },
          "revalidate_objects": {
            "description": "Object types to re-fetch from Stripe API on webhook (e.g. [\"subscription\"])",
            "type": "array",
            "items": { "type": "string" }
          },
          "backfill_limit": {
            "description": "Max objects to backfill per stream (useful for testing)",
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "rate_limit": {
            "description": "Max Stripe API requests per second (default: 25)",
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "backfill_concurrency": {
            "description": "Number of time-range segments for parallel backfill (default: 200)",
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          }
        },
        "required": ["type", "api_key"],
        "additionalProperties": false
      },
      "PostgresDestinationConfig": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["postgres"] },
          "url": {
            "description": "Postgres connection string (alias for connection_string)",
            "type": "string"
          },
          "connection_string": { "description": "Postgres connection string", "type": "string" },
          "host": { "description": "Postgres host (required for AWS IAM)", "type": "string" },
          "port": { "default": 5432, "description": "Postgres port", "type": "number" },
          "database": { "description": "Database name (required for AWS IAM)", "type": "string" },
          "user": { "description": "Database user (required for AWS IAM)", "type": "string" },
          "schema": {
            "type": "string",
            "description": "Target schema name (e.g. \"stripe_sync\")"
          },
          "batch_size": {
            "default": 100,
            "description": "Records to buffer before flushing",
            "type": "number"
          },
          "aws": {
            "description": "AWS RDS IAM authentication config",
            "type": "object",
            "properties": {
              "region": { "type": "string", "description": "AWS region for RDS instance" },
              "role_arn": {
                "description": "IAM role ARN to assume (cross-account)",
                "type": "string"
              },
              "external_id": { "description": "External ID for STS AssumeRole", "type": "string" }
            },
            "required": ["region"],
            "additionalProperties": false
          },
          "ssl_ca_pem": {
            "description": "PEM-encoded CA certificate for SSL verification (required for verify-ca / verify-full with a private CA)",
            "type": "string"
          }
        },
        "required": ["type", "port", "schema", "batch_size"],
        "additionalProperties": false
      },
      "GoogleSheetsDestinationConfig": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["google-sheets"] },
          "client_id": {
            "description": "Google OAuth2 client ID (env: GOOGLE_CLIENT_ID)",
            "type": "string"
          },
          "client_secret": {
            "description": "Google OAuth2 client secret (env: GOOGLE_CLIENT_SECRET)",
            "type": "string"
          },
          "access_token": { "type": "string", "description": "OAuth2 access token" },
          "refresh_token": { "type": "string", "description": "OAuth2 refresh token" },
          "spreadsheet_id": {
            "description": "Target spreadsheet ID (created if omitted)",
            "type": "string"
          },
          "spreadsheet_title": {
            "default": "Stripe Sync",
            "description": "Title when creating a new spreadsheet",
            "type": "string"
          },
          "batch_size": {
            "default": 50,
            "description": "Rows per Sheets API append call",
            "type": "number"
          }
        },
        "required": ["type", "access_token", "refresh_token", "spreadsheet_title", "batch_size"],
        "additionalProperties": false
      },
      "SourceConfig": {
        "discriminator": { "propertyName": "type" },
        "oneOf": [{ "$ref": "#/components/schemas/StripeSourceConfig" }]
      },
      "DestinationConfig": {
        "discriminator": { "propertyName": "type" },
        "oneOf": [
          { "$ref": "#/components/schemas/PostgresDestinationConfig" },
          { "$ref": "#/components/schemas/GoogleSheetsDestinationConfig" }
        ]
      },
      "PipelineConfig": {
        "type": "object",
        "required": ["source", "destination"],
        "properties": {
          "source": { "$ref": "#/components/schemas/SourceConfig" },
          "destination": { "$ref": "#/components/schemas/DestinationConfig" },
          "streams": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name"],
              "properties": {
                "name": { "type": "string" },
                "sync_mode": { "type": "string", "enum": ["incremental", "full_refresh"] },
                "fields": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      }
    }
  }
}
