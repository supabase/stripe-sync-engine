{
  "name": "@stripe/sync-engine",
  "version": "0.1.0",
  "private": false,
  "description": "Stripe Sync Engine — sync Stripe data to Postgres",
  "type": "module",
  "bin": {
    "sync-engine": "./src/cli.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    },
    "bin": {
      "sync-engine": "./dist/cli.js"
    }
  },
  "scripts": {
    "build": "tsup && sed -i '' 's|#!/usr/bin/env tsx|#!/usr/bin/env node|' dist/cli.js",
    "dev": "tsup --watch",
    "test": "vitest --passWithNoTests"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@hono/node-server": "^1",
    "@hono/swagger-ui": "^0.6",
    "@hono/zod-openapi": "^1.2",
    "@stripe/destination-google-sheets": "workspace:*",
    "@stripe/destination-postgres": "workspace:*",
    "@stripe/source-stripe": "workspace:*",
    "@stripe/stateless-sync": "workspace:*",
    "@stripe/store-postgres": "workspace:*",
    "@stripe/sync-engine-stateless": "workspace:*",
    "@stripe/ts-cli": "workspace:*",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "googleapis": "^148.0.0",
    "hono": "^4",
    "pg": "^8.16.3",
    "stripe": "^17.7.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.4",
    "tsup": "^8.5.0",
    "vitest": "^3.2.4"
  }
}
