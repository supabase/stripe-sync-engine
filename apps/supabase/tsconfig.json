{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "declaration": true,
    "outDir": "dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "declarationMap": true,
    "rootDir": "src"
  },
  "include": ["src/**/*"],
  "exclude": ["src/edge-functions/**/*", "src/**/*.test.ts", "src/**/__tests__/**"]
}
